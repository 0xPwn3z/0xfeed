---
// Ticker — scrolling headline marquee (content injected by feed.ts)
---

<div
    class="ticker-bar"
    style="
    height:28px;
    background:var(--color-bg2);
    border-bottom:1px solid var(--color-border);
    overflow:hidden;
    position:relative;
    display:flex;
    align-items:center;
  "
    aria-live="off"
    aria-label="Scrolling news ticker"
>
    <!-- Static prefix label -->
    <span
        style="
      flex-shrink:0;
      background:var(--color-green);
      color:#000;
      font-family:var(--font-mono);
      font-size:10px;
      font-weight:800;
      letter-spacing:.1em;
      padding:0 10px;
      height:100%;
      display:flex;
      align-items:center;
      z-index:1;
    "
        >LIVE FEED</span
    >

    <!-- Scrolling content area -->
    <div
        style="
      flex:1;
      overflow:hidden;
      height:100%;
      position:relative;
    "
    >
        <div
            id="ticker-content"
            style="
        display:inline-flex;
        align-items:center;
        white-space:nowrap;
        height:100%;
        color:var(--color-text-dim);
        font-family:var(--font-mono);
        font-size:11px;
        animation:ticker 115s linear infinite;
        padding-left:16px;
      "
        >
            <span style="color:var(--color-text-dim)"
                >Initialising feed… standby</span
            >
        </div>
    </div>
</div>
