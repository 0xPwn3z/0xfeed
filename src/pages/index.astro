---
import BaseLayout from "../layouts/BaseLayout.astro";
import Ticker from "../components/Ticker.astro";
import Sidebar from "../components/Sidebar.astro";
import RightPanel from "../components/RightPanel.astro";
---

<BaseLayout title="0xFEED — AI & Cybersecurity Intelligence">
	<!-- ── Sticky header ─────────────────────────────────────────────────────── -->
	<header
		style="
      position:sticky;
      top:0;
      z-index:100;
      height:52px;
      background:var(--color-bg2);
      border-bottom:1px solid var(--color-border);
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:0 20px;
      gap:16px;
    "
	>
		<!-- Logo -->
		<div style="display:flex;align-items:center;gap:10px;flex-shrink:0">
			<span
				class="logo-main"
				style="
          color:var(--color-green);
          font-size:16px;
          font-weight:800;
          letter-spacing:.08em;
          font-family:var(--font-mono);
        "
				>0x<span style="color:var(--color-text-dim)">//</span
				>FEED</span
			>
			<span
				style="
          background:var(--color-green-dark);
          color:var(--color-green-dim);
          font-size:9px;
          font-weight:700;
          letter-spacing:.1em;
          padding:1px 6px;
          border:1px solid var(--color-green-dark);
          border-radius:2px;
        "
				>AI+SEC</span
			>
		</div>

		<!-- Search -->
		<div
			class="search-bar"
			style="flex:1;max-width:440px;position:relative"
		>
			<span
				style="
          position:absolute;left:10px;top:50%;transform:translateY(-50%);
          color:var(--color-text-dim);font-size:12px;pointer-events:none;
        "
				aria-hidden="true">⌕</span
			>
			<input
				id="search-input"
				type="search"
				placeholder="Search articles, sources, CVEs…"
				aria-label="Search articles"
				style="
          width:100%;
          background:var(--color-bg3);
          border:1px solid var(--color-border2);
          color:var(--color-text);
          font-family:var(--font-mono);
          font-size:12px;
          padding:6px 10px 6px 30px;
          border-radius:2px;
          outline:none;
          transition:border-color .15s;
        "
				onfocus="this.style.borderColor='var(--color-green-dim)'"
				onblur="this.style.borderColor='var(--color-border2)'"
			/>
		</div>

		<!-- Right controls -->
		<div
			class="header-status"
			style="display:flex;align-items:center;gap:10px;flex-shrink:0"
		>
			<span
				id="article-count"
				style="color:var(--color-text-dim);font-size:11px"
				>0 articles</span
			>

			<button
				id="refresh-btn"
				class="btn-refresh"
				aria-label="Refresh all feeds"
				style="
          background:var(--color-bg3);
          border:1px solid var(--color-border2);
          color:var(--color-green-dim);
          font-family:var(--font-mono);
          font-size:11px;
          font-weight:700;
          letter-spacing:.05em;
          padding:5px 12px;
          border-radius:2px;
          cursor:pointer;
          transition:background .15s, border-color .15s;
        "
				onmouseenter="this.style.background='var(--color-green-dark)';this.style.borderColor='var(--color-green-dim)'"
				onmouseleave="this.style.background='var(--color-bg3)';this.style.borderColor='var(--color-border2)'"
				>⟳ REFRESH</button
			>
		</div>
	</header>

	<!-- ── Ticker ─────────────────────────────────────────────────────────────── -->
	<Ticker />

	<!-- ── Three-column layout ───────────────────────────────────────────────── -->
	<div
		class="app"
		style="
      display:flex;
      align-items:flex-start;
      min-height:calc(100vh - 80px);
    "
	>
		<!-- Left sidebar -->
		<div class="sidebar-left">
			<Sidebar />
		</div>

		<!-- Main feed column -->
		<main
			class="main-feed"
			style="
        flex:1;
        min-width:0;
        padding:16px;
        min-height:calc(100vh - 80px);
      "
			id="main-content"
			aria-label="Article feed"
		>
			<div id="feed-container" style="max-width:860px;margin:0 auto">
				<!-- Loading skeleton -->
				{
					Array.from({ length: 5 }).map((_, i) => (
						<div
							style="
              background:var(--color-bg2);
              border:1px solid var(--color-border);
              border-left:3px solid var(--color-border2);
              padding:14px 16px;
              margin-bottom:8px;
              border-radius:2px;
            "
						>
							<div style="display:flex;gap:8px;margin-bottom:8px">
								<div
									style={`height:14px;width:${40 + i * 8}px;background:var(--color-border2);border-radius:2px`}
								/>
								<div style="height:14px;width:60px;background:var(--color-border);border-radius:2px;margin-left:auto" />
							</div>
							<div
								style={`height:14px;width:${70 + i * 4}%;background:var(--color-border2);border-radius:2px;margin-bottom:8px`}
							/>
							<div style="height:12px;width:90%;background:var(--color-border);border-radius:2px;margin-bottom:4px" />
							<div style="height:12px;width:75%;background:var(--color-border);border-radius:2px" />
						</div>
					))
				}
			</div>
		</main>

		<!-- Right panel -->
		<div class="sidebar-right">
			<RightPanel />
		</div>
	</div>

	<!-- ── Skip to content link (a11y) ──────────────────────────────────────── -->
	<a
		href="#main-content"
		style="
      position:absolute;
      top:-40px;
      left:0;
      background:var(--color-green);
      color:#000;
      font-family:var(--font-mono);
      font-size:12px;
      font-weight:700;
      padding:8px 16px;
      z-index:99999;
      transition:top .15s;
    "
		onfocus="this.style.top='0'"
		onblur="this.style.top='-40px'">Skip to content</a
	>

	<!-- MOBILE BOTTOM NAV — hidden on desktop via CSS -->
	<nav class="mobile-bottom-nav" id="mobile-bottom-nav">
		<button
			class="mob-nav-btn active"
			onclick="mobileSetFilter('all', this)"
		>
			<span class="mob-nav-dot dot-all"></span>
			<span>ALL</span>
		</button>
		<button class="mob-nav-btn" onclick="mobileSetFilter('ai', this)">
			<span class="mob-nav-dot dot-ai"></span>
			<span>AI</span>
		</button>
		<button class="mob-nav-btn" onclick="mobileSetFilter('sec', this)">
			<span class="mob-nav-dot dot-sec"></span>
			<span>SEC</span>
		</button>
		<button class="mob-nav-btn" onclick="mobileSetFilter('bb', this)">
			<span class="mob-nav-dot dot-bb"></span>
			<span>BB</span>
		</button>
		<button class="mob-nav-btn" onclick="toggleMobileDrawer()">
			<span style="font-size:16px">⚙</span>
			<span>MORE</span>
		</button>
	</nav>

	<!-- MOBILE DRAWER OVERLAY -->
	<div
		class="mobile-drawer-overlay"
		id="mobile-drawer-overlay"
		onclick="closeMobileDrawer()"
	>
	</div>

	<!-- MOBILE DRAWER (bottom sheet) -->
	<div class="mobile-drawer" id="mobile-drawer">
		<div class="mobile-drawer-handle"></div>

		<div class="drawer-section">
			<div class="drawer-label">// ADD SOURCE</div>
			<div class="add-source-form">
				<input
					class="form-input"
					id="mob-src-name"
					placeholder="Source name"
					type="text"
				/>
				<input
					class="form-input"
					id="mob-src-url"
					placeholder="RSS feed URL"
					type="url"
				/>
				<select class="form-select" id="mob-src-cat">
					<option value="ai">AI / Research</option>
					<option value="sec">Cybersecurity</option>
					<option value="bb">Bug Bounty / PoC</option>
				</select>
				<button class="btn-add" onclick="addCustomSourceMobile()"
					>+ ADD SOURCE</button
				>
				<div id="mob-form-error" class="error-msg" style="display:none">
				</div>
			</div>
		</div>

		<div class="drawer-section">
			<div class="drawer-label">// CVE SEVERITY</div>
			<div id="mob-cve-stats"></div>
		</div>

		<div class="drawer-section">
			<div class="drawer-label">// SESSION</div>
			<div class="mob-session-stats">
				<div>Items: <span id="mob-stat-loaded">—</span></div>
				<div>Sources: <span id="mob-stat-sources">—</span></div>
				<div>
					Errors: <span
						id="mob-stat-errors"
						style="color:var(--color-red)">—</span>
				</div>
				<div>Refreshed: <span id="mob-stat-refresh">—</span></div>
			</div>
		</div>
	</div>
</BaseLayout>

<!-- ── Feed init script ────────────────────────────────────────────────────── -->
<script>
	import { initFeed } from "../scripts/feed.ts";
	(async () => {
		await initFeed();
	})();
</script>

<!-- ── Responsive styles ───────────────────────────────────────────────────── -->
<style>
	/* Responsive breakpoints are in global.css (768px single breakpoint) */
</style>
